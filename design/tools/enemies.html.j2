<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Enemy Catalogue — Design View</title>
<style>
  :root {
    --bg: #f6f7f9; --panel: #ffffff; --ink: #1a1d21; --muted: #626873;
    --line: #e2e5ea; --accent: #4b6bfb; --chip: #eef1f6; --chip-on: #4b6bfb;
    --chip-on-ink: #ffffff; --shadow: 0 1px 2px rgba(0,0,0,.06), 0 4px 14px rgba(0,0,0,.05);
    --common: #7a828f; --rare: #d9a441; --boss: #d7263d; --biome: #2a9d8f;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #14161a; --panel: #1c1f26; --ink: #e7eaef; --muted: #9aa2b1;
      --line: #2a2e37; --accent: #7f97ff; --chip: #262a33; --chip-on: #7f97ff;
      --chip-on-ink: #10121a; --shadow: 0 1px 2px rgba(0,0,0,.4);
      --common: #9aa2b1; --rare: #e9be6a; --boss: #ff5c6c; --biome: #4fc9b9;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0; background: var(--bg); color: var(--ink);
    font: 15px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  header { padding: 28px 24px 8px; max-width: 1200px; margin: 0 auto; }
  h1 { margin: 0 0 4px; font-size: 24px; letter-spacing: -.01em; }
  .sub { color: var(--muted); font-size: 14px; }
  .toolbar {
    position: sticky; top: 0; z-index: 5; background: var(--bg);
    padding: 12px 24px; border-bottom: 1px solid var(--line);
  }
  .toolbar-inner { max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; gap: 10px; }
  .row1 { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
  input[type=search], select {
    font: inherit; color: inherit; background: var(--panel);
    border: 1px solid var(--line); border-radius: 8px; padding: 8px 10px;
  }
  input[type=search] { flex: 1 1 260px; min-width: 200px; }
  .count { color: var(--muted); font-size: 13px; white-space: nowrap; }
  button.reset {
    font: inherit; color: var(--muted); background: transparent;
    border: 1px solid var(--line); border-radius: 8px; padding: 8px 12px; cursor: pointer;
  }
  button.reset:hover { color: var(--ink); border-color: var(--muted); }
  .facets { display: flex; flex-wrap: wrap; gap: 6px 14px; }
  .facet { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .facet > .flabel { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: .04em; }
  .chip {
    font: inherit; font-size: 12.5px; cursor: pointer; user-select: none;
    background: var(--chip); border: 1px solid transparent; color: var(--ink);
    border-radius: 999px; padding: 3px 10px; line-height: 1.4;
  }
  .chip[aria-pressed="true"] { background: var(--chip-on); color: var(--chip-on-ink); }
  main { max-width: 1200px; margin: 0 auto; padding: 18px 24px 60px; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 14px; }
  .card {
    background: var(--panel); border: 1px solid var(--line); border-radius: 12px;
    padding: 14px 16px 15px; box-shadow: var(--shadow); display: flex; flex-direction: column; gap: 9px;
  }
  .card-head { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .card-head .name { font-weight: 650; font-size: 16px; }
  .badge { font-size: 11px; font-weight: 650; text-transform: uppercase; letter-spacing: .03em;
           padding: 2px 8px; border-radius: 999px; color: #fff; }
  .badge.rar-common { background: var(--common); } .badge.rar-rare { background: var(--rare); }
  .badge.rar-boss { background: var(--boss); }
  .badge.biome { background: transparent; color: var(--biome); border: 1px solid var(--biome); }
  .desc { color: var(--muted); font-size: 13.5px; margin: 0; }
  .stats { display: grid; grid-template-columns: auto 1fr; gap: 3px 10px; font-size: 13px; }
  .stats dt { color: var(--muted); }
  .stats dd { margin: 0; }
  .stats dd code { background: var(--chip); border-radius: 4px; padding: 0 4px; font-size: 12px; }
  .pills { display: flex; flex-wrap: wrap; gap: 4px; }
  .pill { font-size: 11.5px; background: var(--chip); border-radius: 6px; padding: 1px 7px; }
  .note { color: var(--muted); font-size: 12.5px; margin: 0; font-style: italic; }
  .empty { text-align: center; color: var(--muted); padding: 60px 0; }
</style>
</head>
<body>
<header>
  <h1>Enemy Catalogue</h1>
  <div class="sub">Design view generated from <code>design/data/enemies.yaml</code>. Filter, search, and sort while balancing.</div>
</header>

<div class="toolbar">
  <div class="toolbar-inner">
    <div class="row1">
      <input type="search" id="q" placeholder="Search name, behaviour, casts, drops…" autocomplete="off">
      <label class="count">Sort
        <select id="sort">
          <option value="biome">Biome</option>
          <option value="name">Name</option>
          <option value="rarity">Rarity</option>
          <option value="hp">HP</option>
        </select>
      </label>
      <span class="count" id="count"></span>
      <button class="reset" id="reset">Reset</button>
    </div>
    <div class="facets" id="facets"></div>
  </div>
</div>

<main>
  <div class="grid" id="grid"></div>
  <div class="empty" id="empty" hidden>No enemies match these filters.</div>
</main>

<script id="data" type="application/json">{{ data_json }}</script>
<script>
(function () {
  "use strict";
  var DATA = JSON.parse(document.getElementById("data").textContent);
  var ENEMIES = DATA.enemies;
  var ORDER = DATA.ordered;

  var FACETS = [
    { key: "biome", label: "Biome", vals: function (e) { return e.biomes; } },
    { key: "rarity", label: "Rarity", vals: function (e) { return [e.rarity]; } },
    { key: "hp", label: "HP", vals: function (e) { return [e.hp]; } },
    { key: "detection", label: "Detection", vals: function (e) { return [e.detection]; } },
    { key: "casts", label: "Casts", vals: function (e) { return e.casts; } },
    { key: "drops", label: "Drops", vals: function (e) { return e.drops.map(function (d) { return d.spell; }); } }
  ];

  // Ordinal rank for ordered facets; -1 keeps insertion/alpha order otherwise.
  function rankFor(key, value) {
    var scale = ORDER[key];
    if (!scale) return -1;
    var i = scale.indexOf(value);
    return i < 0 ? 99 : i;
  }
  function biomeRank(name) { var i = DATA.biome_order.indexOf(name); return i < 0 ? 99 : i; }

  function optionsFor(f) {
    var present = {};
    ENEMIES.forEach(function (e) { f.vals(e).forEach(function (v) { present[v] = true; }); });
    var vals = Object.keys(present);
    if (f.key === "biome") vals.sort(function (a, b) { return biomeRank(a) - biomeRank(b); });
    else if (rankFor(f.key, vals[0]) >= 0) vals.sort(function (a, b) { return rankFor(f.key, a) - rankFor(f.key, b); });
    else vals.sort();
    return vals;
  }

  var active = {};
  FACETS.forEach(function (f) { active[f.key] = new Set(); });

  var facetsEl = document.getElementById("facets");
  FACETS.forEach(function (f) {
    var wrap = document.createElement("div");
    wrap.className = "facet";
    var lab = document.createElement("span");
    lab.className = "flabel";
    lab.textContent = f.label;
    wrap.appendChild(lab);
    optionsFor(f).forEach(function (v) {
      var b = document.createElement("button");
      b.className = "chip";
      b.type = "button";
      b.textContent = v;
      b.setAttribute("aria-pressed", "false");
      b.addEventListener("click", function () {
        var on = b.getAttribute("aria-pressed") === "true";
        b.setAttribute("aria-pressed", on ? "false" : "true");
        if (on) active[f.key].delete(v); else active[f.key].add(v);
        render();
      });
      wrap.appendChild(b);
    });
    facetsEl.appendChild(wrap);
  });

  var qEl = document.getElementById("q");
  var sortEl = document.getElementById("sort");
  var gridEl = document.getElementById("grid");
  var emptyEl = document.getElementById("empty");
  var countEl = document.getElementById("count");

  function matches(e) {
    for (var i = 0; i < FACETS.length; i++) {
      var f = FACETS[i];
      var sel = active[f.key];
      if (sel.size === 0) continue;
      var hit = f.vals(e).some(function (v) { return sel.has(v); });
      if (!hit) return false;
    }
    var q = qEl.value.trim().toLowerCase();
    if (q) {
      var hay = (e.name + " " + e.description + " " + e.attack + " " +
                 e.casts.join(" ") + " " + e.drops.map(function (d) { return d.spell; }).join(" ") +
                 " " + e.notes).toLowerCase();
      if (hay.indexOf(q) < 0) return false;
    }
    return true;
  }

  function sortKey(mode) {
    return function (a, b) {
      if (mode === "name") return a.name.localeCompare(b.name);
      if (mode === "biome") {
        var r = biomeRank(a.biomes[0]) - biomeRank(b.biomes[0]);
        return r !== 0 ? r : a.name.localeCompare(b.name);
      }
      var ra = rankFor(mode, a[mode]), rb = rankFor(mode, b[mode]);
      return ra !== rb ? ra - rb : a.name.localeCompare(b.name);
    };
  }

  // Render a stat cell that may contain `inline code` from the design prose.
  function withCode(text) {
    var frag = document.createDocumentFragment();
    text.split(/(`[^`]+`)/).forEach(function (part) {
      if (part.charAt(0) === "`" && part.charAt(part.length - 1) === "`") {
        var c = document.createElement("code"); c.textContent = part.slice(1, -1);
        frag.appendChild(c);
      } else if (part) {
        frag.appendChild(document.createTextNode(part));
      }
    });
    return frag;
  }

  function card(e) {
    var el = document.createElement("article");
    el.className = "card";

    var head = document.createElement("div");
    head.className = "card-head";
    var nm = document.createElement("span");
    nm.className = "name";
    nm.textContent = e.name;
    head.appendChild(nm);
    var rb = document.createElement("span");
    rb.className = "badge rar-" + e.rarity;
    rb.textContent = e.rarity === "boss" && e.sub_biome ? "boss · " + e.sub_biome : e.rarity;
    head.appendChild(rb);
    e.biomes.forEach(function (bn) {
      var bb = document.createElement("span");
      bb.className = "badge biome";
      bb.textContent = bn;
      head.appendChild(bb);
    });
    el.appendChild(head);

    var d = document.createElement("p");
    d.className = "desc";
    d.textContent = e.description;
    el.appendChild(d);

    var dl = document.createElement("dl");
    dl.className = "stats";
    function stat(k, node) {
      var dt = document.createElement("dt"); dt.textContent = k;
      var dd = document.createElement("dd");
      if (typeof node === "string") dd.textContent = node; else dd.appendChild(node);
      dl.appendChild(dt); dl.appendChild(dd);
    }
    function pillRow(items) {
      var pills = document.createElement("div"); pills.className = "pills";
      items.forEach(function (t) {
        var p = document.createElement("span"); p.className = "pill"; p.textContent = t;
        pills.appendChild(p);
      });
      return pills;
    }
    stat("HP", e.hp);
    stat("Speed", e.speed);
    stat("Detection", e.detection);
    stat("Attack", withCode(e.attack));
    stat("Casts", pillRow(e.casts));
    stat("Drops", pillRow(e.drops.map(function (dr) { return dr.spell + " t" + dr.tier; })));
    el.appendChild(dl);

    if (e.notes) {
      var n = document.createElement("p");
      n.className = "note";
      n.textContent = e.notes;
      el.appendChild(n);
    }
    return el;
  }

  function render() {
    var list = ENEMIES.filter(matches).sort(sortKey(sortEl.value));
    gridEl.innerHTML = "";
    list.forEach(function (e) { gridEl.appendChild(card(e)); });
    emptyEl.hidden = list.length !== 0;
    countEl.textContent = list.length + " / " + ENEMIES.length + " enemies";
  }

  qEl.addEventListener("input", render);
  sortEl.addEventListener("change", render);
  document.getElementById("reset").addEventListener("click", function () {
    qEl.value = "";
    FACETS.forEach(function (f) { active[f.key].clear(); });
    Array.prototype.forEach.call(document.querySelectorAll(".chip"), function (c) {
      c.setAttribute("aria-pressed", "false");
    });
    render();
  });

  render();
})();
</script>
</body>
</html>
