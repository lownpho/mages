<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Biome Rooms — Design View</title>
<style>
  :root {
    --bg: #f6f7f9; --panel: #ffffff; --ink: #1a1d21; --muted: #626873;
    --line: #e2e5ea; --accent: #4b6bfb; --chip: #eef1f6; --chip-on: #4b6bfb;
    --chip-on-ink: #ffffff; --shadow: 0 1px 2px rgba(0,0,0,.06), 0 4px 14px rgba(0,0,0,.05);
    --tier: #4b6bfb; --room: #2a9d8f; --biome: #b5179e;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #14161a; --panel: #1c1f26; --ink: #e7eaef; --muted: #9aa2b1;
      --line: #2a2e37; --accent: #7f97ff; --chip: #262a33; --chip-on: #7f97ff;
      --chip-on-ink: #10121a; --shadow: 0 1px 2px rgba(0,0,0,.4);
      --tier: #7f97ff; --room: #4fc9b9; --biome: #e368cd;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0; background: var(--bg); color: var(--ink);
    font: 15px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  header { padding: 28px 24px 8px; max-width: 1200px; margin: 0 auto; }
  h1 { margin: 0 0 4px; font-size: 24px; letter-spacing: -.01em; }
  .sub { color: var(--muted); font-size: 14px; }
  .toolbar {
    position: sticky; top: 0; z-index: 5; background: var(--bg);
    padding: 12px 24px; border-bottom: 1px solid var(--line);
  }
  .toolbar-inner { max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; gap: 10px; }
  .row1 { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
  input[type=search], select {
    font: inherit; color: inherit; background: var(--panel);
    border: 1px solid var(--line); border-radius: 8px; padding: 8px 10px;
  }
  input[type=search] { flex: 1 1 260px; min-width: 200px; }
  .count { color: var(--muted); font-size: 13px; white-space: nowrap; }
  button.reset {
    font: inherit; color: var(--muted); background: transparent;
    border: 1px solid var(--line); border-radius: 8px; padding: 8px 12px; cursor: pointer;
  }
  button.reset:hover { color: var(--ink); border-color: var(--muted); }
  .facets { display: flex; flex-wrap: wrap; gap: 6px 14px; }
  .facet { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .facet > .flabel { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: .04em; }
  .chip {
    font: inherit; font-size: 12.5px; cursor: pointer; user-select: none;
    background: var(--chip); border: 1px solid transparent; color: var(--ink);
    border-radius: 999px; padding: 3px 10px; line-height: 1.4;
  }
  .chip[aria-pressed="true"] { background: var(--chip-on); color: var(--chip-on-ink); }
  main { max-width: 1200px; margin: 0 auto; padding: 18px 24px 60px; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }
  .card {
    background: var(--panel); border: 1px solid var(--line); border-radius: 12px;
    padding: 13px 15px 14px; box-shadow: var(--shadow); display: flex; flex-direction: column; gap: 9px;
  }
  .card-head { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .badge { font-size: 11px; font-weight: 650; text-transform: uppercase; letter-spacing: .03em;
           padding: 2px 8px; border-radius: 999px; color: #fff; }
  .badge.tier { background: var(--tier); } .badge.room { background: var(--room); }
  .badge.biome { background: transparent; color: var(--biome); border: 1px solid var(--biome); }
  .sub-b { color: var(--muted); font-size: 12px; margin-left: auto; }
  .vars { display: flex; flex-direction: column; gap: 5px; }
  .var { font-size: 13px; background: var(--chip); border-radius: 7px; padding: 4px 9px; }
  .var.empty { color: var(--muted); font-style: italic; background: transparent; padding-left: 0; }
  .empty { text-align: center; color: var(--muted); padding: 60px 0; }
</style>
</head>
<body>
<header>
  <h1>Biome Rooms</h1>
  <div class="sub">Design view generated from <code>design/data/biomes.yaml</code>. Each card is one room slot; a room rolls one of its variations. Filter by biome, tier, and room type.</div>
</header>

<div class="toolbar">
  <div class="toolbar-inner">
    <div class="row1">
      <input type="search" id="q" placeholder="Search enemy groups…" autocomplete="off">
      <label class="count">Sort
        <select id="sort">
          <option value="loc">Biome › tier</option>
          <option value="tier">Tier</option>
          <option value="room">Room type</option>
        </select>
      </label>
      <span class="count" id="count"></span>
      <button class="reset" id="reset">Reset</button>
    </div>
    <div class="facets" id="facets"></div>
  </div>
</div>

<main>
  <div class="grid" id="grid"></div>
  <div class="empty" id="empty" hidden>No rooms match these filters.</div>
</main>

<script id="data" type="application/json">{{ data_json }}</script>
<script>
(function () {
  "use strict";
  var DATA = JSON.parse(document.getElementById("data").textContent);
  var ROOMS = DATA.rooms;
  var ORDER = DATA.ordered;

  var FACETS = [
    { key: "biome", label: "Biome", vals: function (r) { return [r.biome]; } },
    { key: "sub_biome", label: "Sub-biome", vals: function (r) { return [r.sub_biome]; } },
    { key: "tier", label: "Tier", vals: function (r) { return [r.tier]; } },
    { key: "room", label: "Room", vals: function (r) { return [r.room]; } }
  ];

  function rankFor(key, value) {
    var scale = ORDER[key];
    if (!scale) return -1;
    var i = scale.indexOf(value);
    return i < 0 ? 99 : i;
  }
  function biomeRank(name) { var i = DATA.biome_order.indexOf(name); return i < 0 ? 99 : i; }

  function optionsFor(f) {
    var present = {};
    ROOMS.forEach(function (r) { f.vals(r).forEach(function (v) { present[v] = true; }); });
    var vals = Object.keys(present);
    if (f.key === "biome") vals.sort(function (a, b) { return biomeRank(a) - biomeRank(b); });
    else if (rankFor(f.key, vals[0]) >= 0) vals.sort(function (a, b) { return rankFor(f.key, a) - rankFor(f.key, b); });
    else vals.sort();
    return vals;
  }

  var active = {};
  FACETS.forEach(function (f) { active[f.key] = new Set(); });

  var facetsEl = document.getElementById("facets");
  FACETS.forEach(function (f) {
    var wrap = document.createElement("div");
    wrap.className = "facet";
    var lab = document.createElement("span");
    lab.className = "flabel";
    lab.textContent = f.label;
    wrap.appendChild(lab);
    optionsFor(f).forEach(function (v) {
      var b = document.createElement("button");
      b.className = "chip";
      b.type = "button";
      b.textContent = v;
      b.setAttribute("aria-pressed", "false");
      b.addEventListener("click", function () {
        var on = b.getAttribute("aria-pressed") === "true";
        b.setAttribute("aria-pressed", on ? "false" : "true");
        if (on) active[f.key].delete(v); else active[f.key].add(v);
        render();
      });
      wrap.appendChild(b);
    });
    facetsEl.appendChild(wrap);
  });

  var qEl = document.getElementById("q");
  var sortEl = document.getElementById("sort");
  var gridEl = document.getElementById("grid");
  var emptyEl = document.getElementById("empty");
  var countEl = document.getElementById("count");

  function matches(r) {
    for (var i = 0; i < FACETS.length; i++) {
      var f = FACETS[i];
      var sel = active[f.key];
      if (sel.size === 0) continue;
      var hit = f.vals(r).some(function (v) { return sel.has(v); });
      if (!hit) return false;
    }
    var q = qEl.value.trim().toLowerCase();
    if (q && r.groups.toLowerCase().indexOf(q) < 0) return false;
    return true;
  }

  function sortKey(mode) {
    return function (a, b) {
      if (mode === "tier") return rankFor("tier", a.tier) - rankFor("tier", b.tier) || a.biome.localeCompare(b.biome);
      if (mode === "room") return a.room.localeCompare(b.room) || rankFor("tier", a.tier) - rankFor("tier", b.tier);
      // loc: biome, then sub-biome, then tier (stable within — keeps table order)
      return (biomeRank(a.biome) - biomeRank(b.biome)) ||
             a.sub_biome.localeCompare(b.sub_biome) ||
             (rankFor("tier", a.tier) - rankFor("tier", b.tier));
    };
  }

  // Strip markdown emphasis so "1× viper *(rare)*" reads as plain text.
  function plain(s) { return s.replace(/\*+/g, ""); }

  function card(r) {
    var el = document.createElement("article");
    el.className = "card";

    var head = document.createElement("div");
    head.className = "card-head";
    var tb = document.createElement("span"); tb.className = "badge tier"; tb.textContent = r.tier;
    head.appendChild(tb);
    var rb = document.createElement("span"); rb.className = "badge room"; rb.textContent = r.room;
    head.appendChild(rb);
    var bb = document.createElement("span"); bb.className = "badge biome"; bb.textContent = r.biome;
    head.appendChild(bb);
    var sb = document.createElement("span"); sb.className = "sub-b"; sb.textContent = r.sub_biome;
    head.appendChild(sb);
    el.appendChild(head);

    var vars = document.createElement("div");
    vars.className = "vars";
    r.variations.forEach(function (v) {
      var row = document.createElement("div");
      var text = plain(v);
      if (text === "(empty)" || text === "") { row.className = "var empty"; row.textContent = "— empty —"; }
      else { row.className = "var"; row.textContent = text; }
      vars.appendChild(row);
    });
    el.appendChild(vars);
    return el;
  }

  function render() {
    var list = ROOMS.filter(matches).sort(sortKey(sortEl.value));
    gridEl.innerHTML = "";
    list.forEach(function (r) { gridEl.appendChild(card(r)); });
    emptyEl.hidden = list.length !== 0;
    countEl.textContent = list.length + " / " + ROOMS.length + " rooms";
  }

  qEl.addEventListener("input", render);
  sortEl.addEventListener("change", render);
  document.getElementById("reset").addEventListener("click", function () {
    qEl.value = "";
    FACETS.forEach(function (f) { active[f.key].clear(); });
    Array.prototype.forEach.call(document.querySelectorAll(".chip"), function (c) {
      c.setAttribute("aria-pressed", "false");
    });
    render();
  });

  render();
})();
</script>
</body>
</html>
