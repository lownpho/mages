<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Biome Rooms — Design View</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Silkscreen:wght@400;700&family=VT323&display=swap" rel="stylesheet">
<link rel="stylesheet" href="mages.css">
<style>
  /* Page-specific only — the rest is the shared mages.css theme. */
  .badge.room { background: var(--cyan); }
  .sub-b { color: var(--grey); margin-left: auto; }
  .vars { display: flex; flex-direction: column; gap: 4px; }
  .var { background: var(--bg-deep); color: var(--dim); padding: 0.15rem 0.45rem; }
  .var.empty { color: var(--grey); background: transparent; padding-left: 0; }
</style>
</head>
<body class="mages">
<div class="doc">

<header>
  <h1 class="doc-title"><span class="m">B</span>iome Rooms</h1>
  <p class="doc-sub">Design view generated from <code>design/data/biomes.yaml</code>. Each card is one room slot; a room rolls one of its variations. Filter by biome, tier, and room type.</p>
</header>

<div class="toolbar panel">
  <div class="row">
      <input type="search" id="q" placeholder="Search enemy groups…" autocomplete="off">
      <label class="lbl" for="sort">Sort</label>
      <select id="sort">
          <option value="loc">Biome › tier</option>
          <option value="tier">Tier</option>
          <option value="room">Room type</option>
      </select>
      <span class="count" id="count"></span>
      <button class="btn" id="reset">reset</button>
  </div>
  <div class="facets" id="facets"></div>
</div>

<main>
  <div class="grid" id="grid"></div>
  <div class="empty" id="empty" hidden>No rooms match these filters.</div>
</main>

</div>

<script id="data" type="application/json">{{ data_json }}</script>
<script>
(function () {
  "use strict";
  var DATA = JSON.parse(document.getElementById("data").textContent);
  var ROOMS = DATA.rooms;
  var ORDER = DATA.ordered;

  var FACETS = [
    { key: "biome", label: "Biome", vals: function (r) { return [r.biome]; } },
    { key: "sub_biome", label: "Sub-biome", vals: function (r) { return [r.sub_biome]; } },
    { key: "tier", label: "Tier", vals: function (r) { return [r.tier]; } },
    { key: "room", label: "Room", vals: function (r) { return [r.room]; } }
  ];

  function rankFor(key, value) {
    var scale = ORDER[key];
    if (!scale) return -1;
    var i = scale.indexOf(value);
    return i < 0 ? 99 : i;
  }
  function biomeRank(name) { var i = DATA.biome_order.indexOf(name); return i < 0 ? 99 : i; }

  function optionsFor(f) {
    var present = {};
    ROOMS.forEach(function (r) { f.vals(r).forEach(function (v) { present[v] = true; }); });
    var vals = Object.keys(present);
    if (f.key === "biome") vals.sort(function (a, b) { return biomeRank(a) - biomeRank(b); });
    else if (rankFor(f.key, vals[0]) >= 0) vals.sort(function (a, b) { return rankFor(f.key, a) - rankFor(f.key, b); });
    else vals.sort();
    return vals;
  }

  var active = {};
  FACETS.forEach(function (f) { active[f.key] = new Set(); });

  var facetsEl = document.getElementById("facets");
  FACETS.forEach(function (f) {
    var wrap = document.createElement("div");
    wrap.className = "facet";
    var lab = document.createElement("span");
    lab.className = "flabel";
    lab.textContent = f.label;
    wrap.appendChild(lab);
    optionsFor(f).forEach(function (v) {
      var b = document.createElement("button");
      b.className = "chip";
      b.type = "button";
      b.textContent = v;
      b.setAttribute("aria-pressed", "false");
      b.addEventListener("click", function () {
        var on = b.getAttribute("aria-pressed") === "true";
        b.setAttribute("aria-pressed", on ? "false" : "true");
        if (on) active[f.key].delete(v); else active[f.key].add(v);
        render();
      });
      wrap.appendChild(b);
    });
    facetsEl.appendChild(wrap);
  });

  var qEl = document.getElementById("q");
  var sortEl = document.getElementById("sort");
  var gridEl = document.getElementById("grid");
  var emptyEl = document.getElementById("empty");
  var countEl = document.getElementById("count");

  function matches(r) {
    for (var i = 0; i < FACETS.length; i++) {
      var f = FACETS[i];
      var sel = active[f.key];
      if (sel.size === 0) continue;
      var hit = f.vals(r).some(function (v) { return sel.has(v); });
      if (!hit) return false;
    }
    var q = qEl.value.trim().toLowerCase();
    if (q && r.groups.toLowerCase().indexOf(q) < 0) return false;
    return true;
  }

  function sortKey(mode) {
    return function (a, b) {
      if (mode === "tier") return rankFor("tier", a.tier) - rankFor("tier", b.tier) || a.biome.localeCompare(b.biome);
      if (mode === "room") return a.room.localeCompare(b.room) || rankFor("tier", a.tier) - rankFor("tier", b.tier);
      // loc: biome, then sub-biome, then tier (stable within — keeps table order)
      return (biomeRank(a.biome) - biomeRank(b.biome)) ||
             a.sub_biome.localeCompare(b.sub_biome) ||
             (rankFor("tier", a.tier) - rankFor("tier", b.tier));
    };
  }

  // Strip markdown emphasis so "1× viper *(rare)*" reads as plain text.
  function plain(s) { return s.replace(/\*+/g, ""); }

  function card(r) {
    var el = document.createElement("article");
    el.className = "card";

    var head = document.createElement("div");
    head.className = "card-head";
    var tb = document.createElement("span"); tb.className = "badge tier"; tb.textContent = r.tier;
    head.appendChild(tb);
    var rb = document.createElement("span"); rb.className = "badge room"; rb.textContent = r.room;
    head.appendChild(rb);
    var bb = document.createElement("span"); bb.className = "badge biome"; bb.textContent = r.biome;
    head.appendChild(bb);
    var sb = document.createElement("span"); sb.className = "sub-b"; sb.textContent = r.sub_biome;
    head.appendChild(sb);
    el.appendChild(head);

    var vars = document.createElement("div");
    vars.className = "vars";
    r.variations.forEach(function (v) {
      var row = document.createElement("div");
      var text = plain(v);
      if (text === "(empty)" || text === "") { row.className = "var empty"; row.textContent = "— empty —"; }
      else { row.className = "var"; row.textContent = text; }
      vars.appendChild(row);
    });
    el.appendChild(vars);
    return el;
  }

  function render() {
    var list = ROOMS.filter(matches).sort(sortKey(sortEl.value));
    gridEl.innerHTML = "";
    list.forEach(function (r) { gridEl.appendChild(card(r)); });
    emptyEl.hidden = list.length !== 0;
    countEl.textContent = list.length + " / " + ROOMS.length + " rooms";
  }

  qEl.addEventListener("input", render);
  sortEl.addEventListener("change", render);
  document.getElementById("reset").addEventListener("click", function () {
    qEl.value = "";
    FACETS.forEach(function (f) { active[f.key].clear(); });
    Array.prototype.forEach.call(document.querySelectorAll(".chip"), function (c) {
      c.setAttribute("aria-pressed", "false");
    });
    render();
  });

  render();
})();
</script>
</body>
</html>
