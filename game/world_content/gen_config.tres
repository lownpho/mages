[resource]
script = ExtResource("cfg")
gen_version = 4
room_slot_tiles = 32
biome_slots = 7
world_width_cells = 2
doors_per_biome_border = 4
spawn_min_dist_from_doors = 3
wall_extra_depth = 5
corner_radius = 6
wall_inset_max = 4
starting_biome = &"glade_start"
prefetch_radius_chunks = 1
biomes = Array[ExtResource("bdef")]([ExtResource("b_gs"), ExtResource("b_gv"), ExtResource("b_dw")])
adjacency = ExtResource("adj")
room_types = Array[ExtResource("rtdef")]([ExtResource("r_shrine"), ExtResource("r_0"), ExtResource("r_1"), ExtResource("r_2"), ExtResource("r_3"), ExtResource("r_4"), ExtResource("r_5"), ExtResource("r_6"), ExtResource("r_7"), ExtResource("r_8"), ExtResource("r_9"), ExtResource("r_10"), ExtResource("r_11"), ExtResource("r_12"), ExtResource("r_13"), ExtResource("r_14"), ExtResource("r_15"), ExtResource("r_16"), ExtResource("r_17"), ExtResource("r_18"), ExtResource("r_19"), ExtResource("r_20"), ExtResource("r_21"), ExtResource("r_22"), ExtResource("r_23"), ExtResource("r_24"), ExtResource("r_25"), ExtResource("r_26"), ExtResource("r_27"), ExtResource("r_28"), ExtResource("r_29"), ExtResource("r_30"), ExtResource("r_31"), ExtResource("r_32"), ExtResource("r_33"), ExtResource("r_34"), ExtResource("r_35"), ExtResource("r_36"), ExtResource("r_37"), ExtResource("r_38"), ExtResource("r_dw0"), ExtResource("r_dw1"), ExtResource("r_dw2"), ExtResource("r_dw3"), ExtResource("r_dw4"), ExtResource("r_dw5"), ExtResource("r_dw6")])
