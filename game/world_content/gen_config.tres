[resource]
script = ExtResource("cfg")
gen_version = 0
room_slot_tiles = 16
wall_noise_period = 2
pocket_seal_max_tiles = 6
biome_slots = 6
world_width_cells = 2
doors_per_biome_border = 4
spawn_min_dist_from_doors = 2
wall_extra_depth = 2
corner_radius = 3
wall_inset_max = 2
starting_biome = &"glade_start"
prefetch_radius_chunks = 1
biomes = Array[ExtResource("bdef")]([ExtResource("b_gs"), ExtResource("b_gv"), ExtResource("b_dw")])
adjacency = ExtResource("adj")
room_types = Array[ExtResource("rtdef")]([ExtResource("r0"), ExtResource("r1"), ExtResource("r2"), ExtResource("r3"), ExtResource("r4"), ExtResource("r5"), ExtResource("r_spawn"), ExtResource("r6"), ExtResource("r7"), ExtResource("r8"), ExtResource("r9"), ExtResource("r10"), ExtResource("r11"), ExtResource("r12"), ExtResource("r13"), ExtResource("r14"), ExtResource("r15"), ExtResource("r16"), ExtResource("r17"), ExtResource("r18"), ExtResource("r19"), ExtResource("r20"), ExtResource("r21"), ExtResource("r22"), ExtResource("r23"), ExtResource("r24"), ExtResource("r25"), ExtResource("r26")])
